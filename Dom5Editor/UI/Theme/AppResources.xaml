<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:Dom5Editor.UI.Views">

    <!-- Merge theme and converters -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AppTheme.xaml"/>
        <ResourceDictionary Source="Converters.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ========================================
         DATA TEMPLATES - Entity ViewModels to Views
         ======================================== -->

    <!-- Monster view using the full MonsterView control -->
    <DataTemplate DataType="{x:Type views:MonsterViewModel}">
        <views:MonsterView/>
    </DataTemplate>

    <!-- Weapon view using the full WeaponView control -->
    <DataTemplate DataType="{x:Type views:WeaponViewModel}">
        <views:WeaponView/>
    </DataTemplate>

    <!-- Armor view using the full ArmorView control -->
    <DataTemplate DataType="{x:Type views:ArmorViewModel}">
        <views:ArmorView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type views:SpellViewModel}">
        <Border Background="{StaticResource BackgroundLightBrush}"
                Padding="20"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="{Binding DisplayName}"
                           Style="{StaticResource HeaderText}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ID, StringFormat='ID: {0}'}"
                           Style="{StaticResource SubHeaderText}"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Spell view coming soon..."
                           Style="{StaticResource MutedText}"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- Item view using the full ItemView control -->
    <DataTemplate DataType="{x:Type views:ItemViewModel}">
        <views:ItemView/>
    </DataTemplate>

