<UserControl x:Class="Dom5Editor.UI.Controls.CustomMagicEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400"
             x:Name="Root">

    <StackPanel>
        <!-- Custom Magic Entries List -->
        <ItemsControl ItemsSource="{Binding CustomMagicItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource BackgroundDarkBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,6" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Status indicators row -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <!-- Modified indicator -->
                                    <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,6,0"
                                            Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FFD700"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSessionEdit}" Value="True">
                                                        <Setter Property="Background" Value="#00CED1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Inherited badge -->
                                    <Border Background="#4A4A4A" CornerRadius="2" Padding="3,1" Margin="0,0,6,0"
                                            Visibility="{Binding IsInherited, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="inh" FontSize="8" Foreground="#888888"/>
                                    </Border>

                                    <!-- Display string -->
                                    <TextBlock Text="{Binding Display}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Path toggle buttons -->
                                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <controls:PathToggleButton Path="F" PathName="Fire"
                                        IsChecked="{Binding HasFire, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#DC3C28" TextColor="White"/>
                                    <controls:PathToggleButton Path="A" PathName="Air"
                                        IsChecked="{Binding HasAir, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#B4B4F0" TextColor="Black"/>
                                    <controls:PathToggleButton Path="W" PathName="Water"
                                        IsChecked="{Binding HasWater, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#3C78C8" TextColor="White"/>
                                    <controls:PathToggleButton Path="E" PathName="Earth"
                                        IsChecked="{Binding HasEarth, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#8B5A2B" TextColor="White"/>
                                    <controls:PathToggleButton Path="S" PathName="Astral"
                                        IsChecked="{Binding HasAstral, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#FFD700" TextColor="Black"/>
                                    <controls:PathToggleButton Path="D" PathName="Death"
                                        IsChecked="{Binding HasDeath, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#323232" TextColor="White"/>
                                    <controls:PathToggleButton Path="N" PathName="Nature"
                                        IsChecked="{Binding HasNature, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#3CA03C" TextColor="White"/>
                                    <controls:PathToggleButton Path="G" PathName="Glamour"
                                        IsChecked="{Binding HasGlamour, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#B464B4" TextColor="White"/>
                                    <controls:PathToggleButton Path="B" PathName="Blood"
                                        IsChecked="{Binding HasBlood, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#8C1414" TextColor="White"/>
                                    <controls:PathToggleButton Path="H" PathName="Holy"
                                        IsChecked="{Binding HasHoly, Mode=TwoWay}"
                                        IsReadOnly="{Binding IsInherited}"
                                        PathColor="#FFFFC8" TextColor="Black"/>
                                </WrapPanel>

                                <!-- Chance/Level input -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Chance:" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding Chance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" FontSize="10" Padding="4,2"
                                             IsEnabled="{Binding IsInherited, Converter={StaticResource InverseBoolConverter}}"
                                             Background="{DynamicResource BackgroundMediumBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             HorizontalContentAlignment="Center"/>
                                    <TextBlock FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="= {0} level(s) + {1}% random">
                                                <Binding Path="Levels"/>
                                                <Binding Path="RandomChance"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Remove button -->
                            <Button Grid.Column="1" Content="×" Width="24" Height="24"
                                    FontSize="14" FontWeight="Bold" Padding="0"
                                    VerticalAlignment="Top" Margin="8,0,0,0"
                                    Command="{Binding RemoveCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsInherited, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    ToolTip="Remove this custom magic entry"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add button -->
        <Button Content="+ Add Random Magic" Padding="8,4" Margin="0,4,0,0"
                HorizontalAlignment="Left"
                Click="OnAddButtonClick"
                ToolTip="Add a new random magic path configuration"/>

        <!-- Empty state message -->
        <TextBlock Text="No random magic configured" FontSize="10" FontStyle="Italic"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                   Visibility="{Binding HasNoItems, RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
    </StackPanel>
</UserControl>
