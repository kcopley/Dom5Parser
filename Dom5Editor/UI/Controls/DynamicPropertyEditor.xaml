<UserControl x:Class="Dom5Editor.UI.Controls.DynamicPropertyEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="300"
             x:Name="Root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main editor row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" MinWidth="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Modified from vanilla indicator bar (gold) -->
            <Rectangle Grid.Column="0" Width="2" Fill="{DynamicResource AccentHighlightBrush}"
                       Margin="0,2,3,2" RadiusX="1" RadiusY="1"
                       Visibility="{Binding IsModified, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                       ToolTip="Modified from vanilla"/>

            <!-- Session edit indicator (cyan dot) with reset button -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsSessionEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                <Ellipse Width="5" Height="5" Fill="{DynamicResource SessionEditBrush}"
                         VerticalAlignment="Center" ToolTip="Edited in this session"/>
                <Button Content="×" FontSize="9" Padding="1,0" Margin="2,0,3,0" MinWidth="12" Height="12"
                        VerticalAlignment="Center" Click="OnResetClick" ToolTip="Reset to original value"
                        Visibility="{Binding ResetCommand, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Property Label -->
            <TextBlock Grid.Column="2" Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModified, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSessionEdit, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Editor area - shows different controls based on EditorMode -->
            <Grid Grid.Column="3">
                <!-- Int Mode: TextBox for integer input -->
                <TextBox x:Name="IntValueTextBox"
                         Text="{Binding IntValue, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=Explicit, Converter={StaticResource NullableIntToStringConverter}}"
                         Style="{DynamicResource TextBoxBase}" VerticalAlignment="Center" FontSize="10" Padding="3,2"
                         PreviewTextInput="OnPreviewTextInput" TextChanged="OnTextChanged" LostFocus="OnLostFocus"
                         Visibility="{Binding IsIntMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Ref Mode: Searchable reference selector -->
                <controls:SearchableReferenceComboBox
                         x:Name="RefSelector"
                         ItemsSource="{Binding RefItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         SelectedId="{Binding RefSelectedId, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                         SelectionChanged="OnRefSelectionChanged"
                         Visibility="{Binding IsRefMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Readonly Mode: Display text -->
                <TextBlock Text="{Binding ReadOnlyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="10" VerticalAlignment="Center" FontStyle="Italic"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding IsReadOnlyMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- String Mode: TextBox for string input -->
                <TextBox x:Name="StringValueTextBox"
                         Text="{Binding StringValue, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                         Style="{DynamicResource TextBoxBase}" VerticalAlignment="Center" FontSize="10" Padding="3,2"
                         TextChanged="OnStringTextChanged" LostFocus="OnStringLostFocus"
                         Visibility="{Binding IsStringMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- Inherited indicator -->
            <Border Grid.Column="4" Background="{DynamicResource AccentSecondaryBrush}" CornerRadius="2"
                    Padding="3,1" Margin="3,0,0,0" VerticalAlignment="Center"
                    Visibility="{Binding IsInherited, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                    ToolTip="Value inherited from copy source">
                <TextBlock Text="inh" Foreground="White" FontSize="8"/>
            </Border>
        </Grid>

        <!-- Secondary display text row (e.g., "Summons: Monster Name" for ref mode) -->
        <TextBlock Grid.Row="1"
                   Text="{Binding SecondaryDisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="11" FontWeight="SemiBold" Margin="4,2,0,0"
                   Foreground="{Binding SecondaryDisplayForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Visibility="{Binding HasSecondaryDisplay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>
