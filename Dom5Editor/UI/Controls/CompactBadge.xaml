<UserControl x:Class="Dom5Editor.UI.Controls.CompactBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Dom5Editor.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="20" d:DesignWidth="100"
             x:Name="Root">

    <Border Background="{Binding BadgeBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderBrush="{Binding BadgeBorder, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="0,0,3,3"
            ToolTip="{Binding Tooltip, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <StackPanel Orientation="Horizontal">

            <!-- Modified indicator (small gold bar) -->
            <Rectangle Width="2" Fill="{DynamicResource AccentHighlightBrush}"
                       Margin="0,0,3,0" RadiusX="1" RadiusY="1"
                       Visibility="{Binding IsModified, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Session edit indicator (cyan dot) -->
            <Ellipse Width="4" Height="4" Fill="{DynamicResource SessionEditBrush}"
                     Margin="0,0,3,0" VerticalAlignment="Center"
                     Visibility="{Binding IsSessionEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Icon (optional) -->
            <Image Width="12" Height="12" Margin="0,0,3,0" VerticalAlignment="Center"
                   Source="{Binding IconSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Visibility="{Binding HasIcon, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <!-- Label -->
            <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="9" VerticalAlignment="Center"
                       Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <!-- Value (for int badges) - only visible when HasValue is true -->
            <TextBlock Text=": " FontSize="9" VerticalAlignment="Center"
                       Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Visibility="{Binding HasValue, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBox x:Name="ValueTextBox"
                     Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                     FontSize="9" MinWidth="20" Padding="1,0" Margin="0,0,0,0"
                     HorizontalContentAlignment="Center" VerticalAlignment="Center"
                     Background="Transparent"
                     Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     BorderThickness="0"
                     Visibility="{Binding HasValue, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                     behaviors:DebouncedTextBoxBehavior.IsEnabled="True"/>

            <!-- Reference display (for ref badges) - only visible when IsReference is true -->
            <TextBlock Text=": " FontSize="9" VerticalAlignment="Center"
                       Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Visibility="{Binding IsReference, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{Binding ReferenceDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="9" VerticalAlignment="Center" FontWeight="SemiBold"
                       Foreground="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Visibility="{Binding IsReference, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                       Cursor="Hand"
                       TextDecorations="Underline"
                       MouseLeftButtonDown="OnReferenceClick"/>

            <!-- Inherited badge -->
            <Border Background="{DynamicResource AccentSecondaryBrush}" CornerRadius="2"
                    Padding="2,0" Margin="3,0,0,0" VerticalAlignment="Center"
                    Visibility="{Binding IsInherited, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="inh" Foreground="White" FontSize="7"/>
            </Border>

            <!-- Remove button -->
            <Button Content="×" FontSize="8" Padding="1,0" Margin="3,0,0,0" MinWidth="12" Height="12"
                    VerticalAlignment="Center"
                    Command="{Binding RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Visibility="{Binding CanRemove, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="{Binding LabelForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
