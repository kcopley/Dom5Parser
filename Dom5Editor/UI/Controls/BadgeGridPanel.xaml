<UserControl x:Class="Dom5Editor.UI.Controls.BadgeGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="400"
             x:Name="Root">

    <StackPanel>
        <!-- Section Header (optional) -->
        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,4"
                   Visibility="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Badge container with uniform grid -->
        <ItemsControl x:Name="BadgeItemsControl" ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding Columns, RelativeSource={RelativeSource AncestorType=local:BadgeGridPanel}}"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:CompactBadge
                        Label="{Binding DisplayName}"
                        Value="{Binding Value, Mode=TwoWay}"
                        HasValue="{Binding HasValue}"
                        BadgeBackground="{Binding Background}"
                        BadgeBorder="{Binding BorderBrush}"
                        LabelForeground="{Binding Foreground}"
                        IsModified="{Binding IsModified}"
                        IsSessionEdit="{Binding IsSessionEdit}"
                        IsInherited="{Binding IsInherited}"
                        CanRemove="{Binding CanRemove}"
                        RemoveCommand="{Binding RemoveCommand, RelativeSource={RelativeSource AncestorType=local:BadgeGridPanel}}"
                        CommandParameter="{Binding}"
                        Tooltip="{Binding Tooltip}"
                        HasIcon="{Binding HasIcon}"
                        IconSource="{Binding IconSource}"
                        IsReference="{Binding IsReference}"
                        ReferenceDisplay="{Binding ReferenceDisplay}"
                        ReferenceType="{Binding ReferenceType}"
                        ReferenceId="{Binding ReferenceId, Mode=TwoWay}"
                        AvailableReferences="{Binding AvailableReferences}"
                        IsReferenceEditable="{Binding IsReferenceEditable}"
                        Margin="0,0,4,4"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Searchable Add ComboBox for properties -->
        <local:SearchableReferenceComboBox
            x:Name="PropertyAddComboBox"
            Width="140" Height="20"
            HorizontalAlignment="Left"
            Margin="0,4,0,0"
            ItemsSource="{Binding SearchablePropertyItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Placeholder="+ Add property..."
            Visibility="{Binding ShowSimpleAddButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
            SelectionChanged="OnPropertyAddSelectionChanged"/>

        <!-- Searchable Add ComboBox (for reference items - entity references) -->
        <local:SearchableReferenceComboBox
            x:Name="SearchableAddComboBox"
            Width="150" Height="20"
            HorizontalAlignment="Left"
            Margin="0,4,0,0"
            ItemsSource="{Binding SearchableAvailableItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Placeholder="+ Add reference..."
            Visibility="{Binding ShowSearchableAddButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
            SelectionChanged="OnSearchableAddSelectionChanged"/>
    </StackPanel>
</UserControl>
