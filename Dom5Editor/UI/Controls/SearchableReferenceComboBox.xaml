<UserControl x:Class="Dom5Editor.UI.Controls.SearchableReferenceComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="22" d:DesignWidth="200"
             x:Name="Root"
             MouseLeftButtonDown="OnControlMouseDown">

    <UserControl.Resources>
        <!-- Style for dropdown items -->
        <Style x:Key="DropdownItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main container with text input and dropdown button -->
        <Border Background="{DynamicResource BackgroundDarkBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="3"
                x:Name="MainBorder"
                Cursor="Hand">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Editable text box for filtering (shows name only) -->
                <TextBox x:Name="FilterTextBox"
                         Grid.Column="0"
                         Text="{Binding FilterText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         FontSize="10"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         GotFocus="OnTextBoxGotFocus"
                         LostFocus="OnTextBoxLostFocus"
                         PreviewKeyDown="OnTextBoxPreviewKeyDown"
                         PreviewMouseLeftButtonDown="OnTextBoxMouseDown"/>

                <!-- ID display (read-only, shown when item is selected) -->
                <TextBlock x:Name="IdDisplay"
                           Grid.Column="1"
                           Text="{Binding DisplayId, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="9"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Visibility="{Binding HasSelectedId, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Dropdown toggle button -->
                <ToggleButton x:Name="DropdownButton"
                              Grid.Column="2"
                              Width="18"
                              IsChecked="{Binding IsDropdownOpen, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0"
                              Focusable="False"
                              Click="OnDropdownButtonClick">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}">
                                <Path x:Name="Arrow"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Arrow" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- Dropdown popup -->
        <Popup x:Name="DropdownPopup"
               IsOpen="{Binding IsDropdownOpen, RelativeSource={RelativeSource AncestorType=UserControl}}"
               PlacementTarget="{Binding ElementName=MainBorder}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="{DynamicResource BackgroundMediumBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="0,0,3,3"
                    MaxHeight="300"
                    MinWidth="200">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filtered items list -->
                    <ListBox x:Name="ItemsListBox"
                             Grid.Row="0"
                             ItemsSource="{Binding FilteredItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             SelectedItem="{Binding SelectedFilteredItem, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource DropdownItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="OnListBoxSelectionChanged"
                             PreviewMouseLeftButtonUp="OnListBoxItemClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="Normal"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" #"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="9"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding ID}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="9"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- No results message -->
                    <TextBlock Grid.Row="0"
                               Text="No matching entities"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Padding="12"
                               Visibility="{Binding HasNoResults, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Result count footer -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource BackgroundDarkBrush}"
                            Padding="6,3"
                            Visibility="{Binding ShowResultCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ResultCountText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="9"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
