<UserControl x:Class="Dom5Editor.UI.Controls.CommandPropertyEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="300"
             x:Name="Root">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Modified from vanilla indicator bar (gold) -->
        <Rectangle Grid.Column="0" Width="3" Fill="{DynamicResource AccentHighlightBrush}"
                   Margin="0,2,4,2" RadiusX="1.5" RadiusY="1.5"
                   Visibility="{Binding IsModified, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                   ToolTip="Modified from vanilla"/>

        <!-- Session edit indicator (cyan dot) with reset button -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                    Visibility="{Binding IsSessionEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Ellipse Width="6" Height="6" Fill="{DynamicResource SessionEditBrush}"
                     VerticalAlignment="Center" ToolTip="Edited in this session"/>
            <Button Content="×" FontSize="10" Padding="2,0" Margin="2,0,4,0" MinWidth="14" Height="14"
                    VerticalAlignment="Center" Click="OnResetClick" ToolTip="Reset to original value"
                    Visibility="{Binding ResetCommand, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- CheckBox with Label -->
        <CheckBox Grid.Column="2"
                  IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                  Content="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="11">
            <CheckBox.Style>
                <Style TargetType="CheckBox" BasedOn="{StaticResource CheckBoxBase}">
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModified, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSessionEdit, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </CheckBox.Style>
        </CheckBox>

        <!-- Inherited indicator -->
        <Border Grid.Column="3" Background="{DynamicResource AccentSecondaryBrush}" CornerRadius="4"
                Padding="4,1" Margin="4,0,0,0" VerticalAlignment="Center"
                Visibility="{Binding IsInherited, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                ToolTip="Value inherited from copystats">
            <TextBlock Text="inh" Foreground="White" FontSize="9"/>
        </Border>
    </Grid>
</UserControl>
