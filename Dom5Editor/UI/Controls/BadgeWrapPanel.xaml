<UserControl x:Class="Dom5Editor.UI.Controls.BadgeWrapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="400"
             x:Name="Root">

    <StackPanel>
        <!-- Section Header (optional) -->
        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,4"
                   Visibility="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Badge container with wrap -->
        <WrapPanel x:Name="BadgeContainer" Orientation="Horizontal">
            <!-- Badges are added here via ItemsSource binding -->
            <ItemsControl ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:CompactBadge
                            Label="{Binding DisplayName}"
                            Value="{Binding Value, Mode=TwoWay}"
                            HasValue="{Binding HasValue}"
                            BadgeBackground="{Binding Background}"
                            BadgeBorder="{Binding BorderBrush}"
                            LabelForeground="{Binding Foreground}"
                            IsModified="{Binding IsModified}"
                            IsSessionEdit="{Binding IsSessionEdit}"
                            IsInherited="{Binding IsInherited}"
                            CanRemove="{Binding CanRemove}"
                            RemoveCommand="{Binding RemoveCommand, RelativeSource={RelativeSource AncestorType=local:BadgeWrapPanel}}"
                            CommandParameter="{Binding}"
                            Tooltip="{Binding Tooltip}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add ComboBox -->
            <ComboBox x:Name="AddComboBox"
                      ItemsSource="{Binding AvailableItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      DisplayMemberPath="DisplayName"
                      Width="70" Height="18" FontSize="9"
                      Margin="0,0,0,3"
                      Visibility="{Binding ShowAddButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"
                      SelectionChanged="OnAddSelectionChanged"
                      PreviewMouseWheel="OnComboBoxPreviewMouseWheel">
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                        <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                    </Style>
                </ComboBox.Style>
            </ComboBox>
        </WrapPanel>
    </StackPanel>
</UserControl>
