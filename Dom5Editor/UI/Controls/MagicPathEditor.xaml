<UserControl x:Class="Dom5Editor.UI.Controls.MagicPathEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Dom5Editor.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="400"
             x:Name="Root">

    <StackPanel>
        <!-- Active Magic Paths as colored badges -->
        <ItemsControl ItemsSource="{Binding MagicPaths, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding PathColor}" CornerRadius="3" Padding="4,2" Margin="0,0,4,4"
                            BorderBrush="{Binding BorderColor}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <!-- Modified indicator (small gold bar) -->
                            <Rectangle Width="2" Fill="{DynamicResource AccentHighlightBrush}"
                                       Margin="0,0,3,0" RadiusX="1" RadiusY="1"
                                       Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ToolTip="Modified from vanilla"/>

                            <!-- Session edit indicator (cyan dot) -->
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource SessionEditBrush}"
                                     Margin="0,0,3,0" VerticalAlignment="Center"
                                     Visibility="{Binding IsSessionEdit, Converter={StaticResource BoolToVisibilityConverter}}"
                                     ToolTip="Added in this session"/>

                            <!-- Path letter -->
                            <TextBlock Text="{Binding PathLetter}" FontSize="11" FontWeight="Bold"
                                       Foreground="{Binding TextColor}" VerticalAlignment="Center"/>

                            <!-- Level value - debounced -->
                            <TextBox Text="{Binding Level, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                     Width="24" FontSize="10" Padding="2,1" Margin="2,0,0,0"
                                     HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                     Background="{DynamicResource BackgroundDarkBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     behaviors:DebouncedTextBoxBehavior.IsEnabled="True"/>

                            <!-- Inherited badge -->
                            <Border Background="{DynamicResource AccentSecondaryBrush}" CornerRadius="2"
                                    Padding="2,0" Margin="2,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsInherited, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTip="Inherited from copystats">
                                <TextBlock Text="inh" Foreground="White" FontSize="7"/>
                            </Border>

                            <!-- Remove button -->
                            <Button Content="×" FontSize="9" Padding="2,0" Margin="3,0,0,0" MinWidth="14" Height="14"
                                    VerticalAlignment="Center"
                                    Command="{Binding RemoveMagicPathCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding CanRemove}"
                                    ToolTip="{Binding RemoveTooltip}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="{Binding TextColor}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}"/>
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add Path dropdown with path buttons -->
        <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
            <TextBlock Text="Add:" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ItemsControl ItemsSource="{Binding AvailablePaths, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="20" Height="18" Margin="0,0,2,0" Padding="0"
                                FontSize="10" FontWeight="Bold" Content="{Binding PathLetter}"
                                ToolTip="{Binding PathName}"
                                Command="{Binding AddMagicPathCommand, ElementName=Root}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="{Binding PathColor}"/>
                                    <Setter Property="Foreground" Value="{Binding TextColor}"/>
                                    <Setter Property="BorderBrush" Value="{Binding BorderColor}"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </WrapPanel>
    </StackPanel>
</UserControl>
