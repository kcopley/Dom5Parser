<UserControl x:Class="Dom5Editor.UI.Views.SpellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID, sprite placeholder, and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Spell icon placeholder -->
                    <Border Grid.Column="0" Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64" Margin="0,0,12,0">
                        <Grid>
                            <!-- Path icon if available -->
                            <Image Width="48" Height="48"
                                   Source="{Binding PrimaryPathLetter, Converter={StaticResource PathLetterToPathIconConverter}}"
                                   Visibility="{Binding PrimaryPathLetter, Converter={StaticResource NullToVisibilityConverter}}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Placeholder when no path -->
                            <TextBlock Text="Spell" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding PrimaryPathLetter, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding ID, StringFormat='Spell #{0}'}" Style="{DynamicResource MutedText}" FontSize="11"/>
                            <TextBlock Text=" - " Style="{DynamicResource MutedText}" FontSize="11"
                                       Visibility="{Binding SchoolDisplay, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding SchoolDisplay}" Style="{DynamicResource MutedText}" FontSize="11" FontWeight="SemiBold"
                                       Visibility="{Binding SchoolDisplay, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding ResearchLevel, StringFormat=' (L{0})'}" Style="{DynamicResource MutedText}" FontSize="11"
                                       Visibility="{Binding ResearchLevel, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="2" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Basic Info Section -->
            <controls:PropertyGroupControl Header="Basic Info" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <controls:StringPropertyEditor Label="Name" Value="{Binding Name, Mode=TwoWay}" Margin="0,0,0,8"/>

                        <!-- Copy From Reference (editable) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Copy From:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <controls:SearchableReferenceComboBox
                                Grid.Column="1"
                                ItemsSource="{Binding AvailableSpellsForCopy}"
                                SelectedId="{Binding CopySpellId, Mode=TwoWay}"
                                Placeholder="Select spell to copy from..."
                                ToolTip="Select a spell to copy properties from"/>
                            <Button Grid.Column="2" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                    ToolTip="Clear copy spell"
                                    Visibility="{Binding HasCopySpell, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Click="OnClearCopySpellClick"/>
                            <Button Grid.Column="3" Content="→" Width="24" Height="24" Margin="4,0,0,0"
                                    ToolTip="Navigate to source spell"
                                    Visibility="{Binding HasCopySpell, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Click="OnCopySpellClick"/>
                        </Grid>
                        <!-- Clear Command -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Clear:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox Grid.Column="1" Content="Clear All" IsChecked="{Binding HasClear, Mode=TwoWay}"
                                      ToolTip="Clear all inherited properties"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Research Section (JSON-driven via BadgeGridPanel) -->
            <controls:PropertyGroupControl Header="Research" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <controls:BadgeGridPanel
                            ItemsSource="{Binding ResearchBadges}"
                            RemoveCommand="{Binding RemoveResearchBadgeCommand}"
                            Columns="3"
                            ShowAddButton="False"/>

                        <!-- School Display Info -->
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6" Margin="0,8,0,0"
                                Visibility="{Binding SchoolDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock>
                                <Run Text="School:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Run Text="{Binding SchoolDisplay, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Path Requirements Section -->
            <controls:PropertyGroupControl Header="Path Requirements" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <!-- Primary Path -->
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding PrimaryPathDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Primary:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Width="60"/>
                                <Image Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center"
                                       Source="{Binding PrimaryPathLetter, Converter={StaticResource PathLetterToPathIconConverter}}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="{Binding PrimaryPathDisplay}" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PrimaryPathLevel, StringFormat=' {0}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Secondary Path -->
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding SecondaryPathDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Secondary:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Width="60"/>
                                <Image Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center"
                                       Source="{Binding SecondaryPathLetter, Converter={StaticResource PathLetterToPathIconConverter}}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="{Binding SecondaryPathDisplay}" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SecondaryPathLevel, StringFormat=' {0}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- No path requirements message -->
                        <TextBlock Text="No path requirements defined" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontStyle="Italic"
                                   Visibility="{Binding HasPathRequirements, Converter={StaticResource BoolToVisibilityInverseConverter}}"/>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Fatigue Cost Display (value edited via Research section) -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
                    Visibility="{Binding FatigueCostDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cost:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FatigueCostDisplay}" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="13" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    <!-- Path gem icon if applicable -->
                    <Image Width="16" Height="16" Margin="4,0,0,0" VerticalAlignment="Center"
                           Source="{Binding PrimaryPathLetter, Converter={StaticResource PathLetterToGemIconConverter}}"
                           Visibility="{Binding GemCost, Converter={StaticResource PositiveIntToVisibilityConverter}}"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </StackPanel>
            </Border>

            <!-- Combat Stats Section (JSON-driven via BadgeGridPanel) -->
            <controls:PropertyGroupControl Header="Combat Stats" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <controls:BadgeGridPanel
                            ItemsSource="{Binding CombatBadges}"
                            RemoveCommand="{Binding RemoveCombatBadgeCommand}"
                            Columns="3"
                            ShowAddButton="False"/>

                        <!-- Next Spell Chain -->
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6" Margin="0,8,0,0"
                                Visibility="{Binding HasNextSpell, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Next Spell:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NextSpellDisplay}" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="11" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"
                                           Cursor="Hand" MouseLeftButtonDown="OnNextSpellClick"
                                           ToolTip="Click to navigate to next spell in chain"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Properties - Badge Panel -->
            <controls:PropertyGroupControl Header="Properties" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeWrapPanel
                        ItemsSource="{Binding PropertyBadges}"
                        AvailableItems="{Binding AvailablePropertyBadges}"
                        RemoveCommand="{Binding RemovePropertyBadgeCommand}"
                        AddCommand="{Binding AddPropertyBadgeCommand}"
                        NavigateCommand="{Binding NavigateToReferenceCommand}"
                        ShowAddButton="True"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
