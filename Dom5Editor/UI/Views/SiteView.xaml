<UserControl x:Class="Dom5Editor.UI.Views.SiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID, sprite placeholder, and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sprite placeholder (sites use #look for sprite number) -->
                    <Border Grid.Column="0" Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64" Margin="0,0,12,0">
                        <Grid>
                            <!-- Sprite image when available -->
                            <Image Source="{Binding SpriteImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Visibility="{Binding SpriteImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <!-- Placeholder when no sprite -->
                            <TextBlock Text="Site" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding SpriteImage, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding ID, StringFormat='Site #{0}'}" Style="{DynamicResource MutedText}" FontSize="11"/>
                            <TextBlock Text=" - " Style="{DynamicResource MutedText}" FontSize="11"
                                       Visibility="{Binding PathLetter, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <Image Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"
                                   Visibility="{Binding PathLetter, Converter={StaticResource NullToVisibilityConverter}}"
                                   Source="{Binding PathLetter, Converter={StaticResource PathLetterToPathIconConverter}}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <TextBlock Text="{Binding PathDisplay}" Style="{DynamicResource MutedText}" FontSize="11" FontWeight="SemiBold"
                                       Visibility="{Binding PathLetter, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Level, StringFormat=' L{0}'}" Style="{DynamicResource MutedText}" FontSize="11"
                                       Visibility="{Binding Level, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="2" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Basic Info Section -->
            <controls:PropertyGroupControl Header="Basic Info" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <controls:StringPropertyEditor Label="Name" Value="{Binding Name, Mode=TwoWay}" Margin="0,0,0,8"/>

                        <!-- Copy From Reference -->
                        <controls:ReferencePropertyEditor
                            Label="Copy From Site"
                            ReferenceId="{Binding CopySiteId, Mode=TwoWay}"
                            ReferenceName="{Binding CopySiteName}"
                            ReferenceType="Site"
                            Margin="0,0,0,8"/>

                        <!-- Core Stats Grid -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <controls:IntPropertyEditor Grid.Column="0" Label="Path" Value="{Binding Path, Mode=TwoWay}"
                                                        IsModified="{Binding IsPathModified}" IsSessionEdit="{Binding IsPathSessionEdit}"
                                                        IsInherited="{Binding IsPathInherited}" Margin="0,0,4,0"/>
                            <controls:IntPropertyEditor Grid.Column="1" Label="Level" Value="{Binding Level, Mode=TwoWay}"
                                                        IsModified="{Binding IsLevelModified}" IsSessionEdit="{Binding IsLevelSessionEdit}"
                                                        IsInherited="{Binding IsLevelInherited}" Margin="4,0,4,0"/>
                            <controls:IntPropertyEditor Grid.Column="2" Label="Rarity" Value="{Binding Rarity, Mode=TwoWay}"
                                                        IsModified="{Binding IsRarityModified}" IsSessionEdit="{Binding IsRaritySessionEdit}"
                                                        IsInherited="{Binding IsRarityInherited}" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Sprite Reference -->
                        <controls:IntPropertyEditor Label="Sprite (#look)" Value="{Binding LookSprite, Mode=TwoWay}"
                                                    IsModified="{Binding IsLookSpriteModified}" IsSessionEdit="{Binding IsLookSpriteSessionEdit}"
                                                    Margin="0,0,0,8"/>

                        <!-- Gems Display (read-only for now) -->
                        <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="8,6"
                                Visibility="{Binding HasGems, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gems:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GemAmount}" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="13" FontWeight="Bold" Margin="6,0,2,0" VerticalAlignment="Center"/>
                                <Image Width="16" Height="16" VerticalAlignment="Center"
                                       Source="{Binding GemLetter, Converter={StaticResource PathLetterToGemIconConverter}}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="{Binding GemPathDisplay, StringFormat=' ({0})'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Properties - Single Unified Badge Panel -->
            <controls:PropertyGroupControl Header="Properties" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeWrapPanel
                        ItemsSource="{Binding PropertyBadges}"
                        AvailableItems="{Binding AvailablePropertyBadges}"
                        RemoveCommand="{Binding RemovePropertyBadgeCommand}"
                        AddCommand="{Binding AddPropertyBadgeCommand}"
                        ShowAddButton="True"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
