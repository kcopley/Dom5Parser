<UserControl x:Class="Dom5Editor.UI.Views.MonsterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sprite Images (compact) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64" Margin="0,0,4,0">
                            <Image Source="{Binding SpriteImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64">
                            <Image Source="{Binding Sprite2Image}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <TextBlock Text="{Binding ID, StringFormat='Monster #{0}'}" Style="{DynamicResource MutedText}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="2" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Basic Info Section -->
            <controls:PropertyGroupControl Header="Basic Info" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:StringPropertyEditor Grid.Column="0" Label="Name" Value="{Binding Name, Mode=TwoWay}" Margin="0,0,4,4"/>
                            <controls:StringPropertyEditor Grid.Column="1" Label="Fixed Name" Value="{Binding FixedName, Mode=TwoWay}" IsModified="{Binding IsFixedNameModified}" IsSessionEdit="{Binding IsFixedNameSessionEdit}" Margin="4,0,0,4"/>
                        </Grid>
                        <controls:StringPropertyEditor Label="Description" Value="{Binding Description, Mode=TwoWay}" IsModified="{Binding IsDescriptionModified}" IsSessionEdit="{Binding IsDescriptionSessionEdit}" IsMultiline="True"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:StringPropertyEditor Grid.Column="0" Label="Sprite 1" Value="{Binding Sprite1, Mode=TwoWay}" IsModified="{Binding IsSprite1Modified}" IsSessionEdit="{Binding IsSprite1SessionEdit}" Margin="0,0,4,0"/>
                            <controls:StringPropertyEditor Grid.Column="1" Label="Sprite 2" Value="{Binding Sprite2, Mode=TwoWay}" IsModified="{Binding IsSprite2Modified}" IsSessionEdit="{Binding IsSprite2SessionEdit}" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Copy From Section (editable) -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                <StackPanel>
                    <!-- CopyStats selector -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Copy Stats:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <controls:SearchableReferenceComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding AvailableMonstersForCopy}"
                            SelectedId="{Binding CopyStatsId, Mode=TwoWay}"
                            Placeholder="Select monster to copy stats from..."
                            ToolTip="Copy all stats from another monster"/>
                        <Button Grid.Column="2" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Clear copy stats"
                                Visibility="{Binding HasCopyStats, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnClearCopyStatsClick"/>
                        <Button Grid.Column="3" Content="→" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Navigate to source monster"
                                Visibility="{Binding HasCopyStats, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnCopyStatsClick"/>
                    </Grid>
                    <!-- CopySpr selector -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Copy Sprite:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <controls:SearchableReferenceComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding AvailableMonstersForCopy}"
                            SelectedId="{Binding CopySprId, Mode=TwoWay}"
                            Placeholder="Select monster to copy sprite from..."
                            ToolTip="Copy sprite from another monster"/>
                        <Button Grid.Column="2" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Clear copy sprite"
                                Visibility="{Binding HasCopySpr, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnClearCopySprClick"/>
                        <Button Grid.Column="3" Content="→" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Navigate to source monster"
                                Visibility="{Binding HasCopySpr, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnCopySprClick"/>
                    </Grid>
                    <!-- Clear Commands -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Clear:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <CheckBox Content="All" IsChecked="{Binding HasClearAll, Mode=TwoWay}" Margin="0,0,12,0"
                                      ToolTip="Clear ALL inherited properties (stats, equipment, magic, abilities)"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                            <CheckBox Content="Weapons" IsChecked="{Binding HasClearWeapons, Mode=TwoWay}" Margin="0,0,12,0"
                                      ToolTip="Clear inherited weapons"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                            <CheckBox Content="Armor" IsChecked="{Binding HasClearArmor, Mode=TwoWay}" Margin="0,0,12,0"
                                      ToolTip="Clear inherited armor"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                            <CheckBox Content="Magic" IsChecked="{Binding HasClearMagic, Mode=TwoWay}" Margin="0,0,12,0"
                                      ToolTip="Clear inherited magic paths"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                            <CheckBox Content="Abilities" IsChecked="{Binding HasClearSpec, Mode=TwoWay}" Margin="0,0,0,0"
                                      ToolTip="Clear inherited special abilities"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                        </WrapPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stats Section (3-column grid, driven by JSON) -->
            <controls:PropertyGroupControl Header="Stats" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeGridPanel
                        Columns="3"
                        ItemsSource="{Binding StatsBadges}"
                        RemoveCommand="{Binding RemoveStatsBadgeCommand}"
                        ShowAddButton="False"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Magic Paths Section -->
            <controls:PropertyGroupControl Header="Magic Paths" IsExpanded="False">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:MagicPathEditor MagicPaths="{Binding MagicPathsList}"
                                              AvailablePaths="{Binding AvailableMagicPaths}"
                                              PathAdded="OnMagicPathAdded"
                                              PathRemoved="OnMagicPathRemoved"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Random Magic (CUSTOMMAGIC) Section -->
            <controls:PropertyGroupControl Header="Random Magic" IsExpanded="False">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <TextBlock Text="Configure random magic path picks for mages. Each entry defines which paths can be picked and the chance value (100 = 1 guaranteed level, 50 = 50% for 1 level, etc.)"
                                   TextWrapping="Wrap" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <controls:CustomMagicEditor
                            CustomMagicItems="{Binding CustomMagicList}"
                            AddRequested="OnCustomMagicAddRequested"
                            RemoveRequested="OnCustomMagicRemoveRequested"/>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Equipment Section (Weapons & Armor) -->
            <controls:PropertyGroupControl Header="Equipment" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Weapons Column (Left) -->
                        <StackPanel Grid.Column="0">
                            <!-- Weapons Header Row -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="WEAPON" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="LEN" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="ATT" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="DMG" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                            </Grid>

                            <!-- Weapon List -->
                            <ItemsControl ItemsSource="{Binding WeaponsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundDarkBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="4,3" Margin="0,0,0,2"
                                                ToolTip="{Binding WeaponTooltip}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Status indicator -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="3" Height="14" CornerRadius="1" Margin="0,0,2,0"
                                                            Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSessionEdit}" Value="True">
                                                                        <Setter Property="Background" Value="#00CED1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <TextBlock Text="i" FontSize="8" Foreground="#666666"
                                                               Visibility="{Binding IsInherited, Converter={StaticResource BoolToVisibilityConverter}}"
                                                               VerticalAlignment="Center" ToolTip="Inherited"/>
                                                </StackPanel>

                                                <!-- Name (clickable) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name, TargetNullValue='(unknown)'}"
                                                           Foreground="{DynamicResource AccentHighlightBrush}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextDecorations="Underline" Cursor="Hand"
                                                           VerticalAlignment="Center"
                                                           MouseLeftButtonDown="OnEquipmentClick"/>

                                                <!-- LEN -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding LengthDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- ATT -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding AttackDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- DMG -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding DamageDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Remove button -->
                                                <Button Grid.Column="5" Content="×" Width="18" Height="18"
                                                        FontSize="12" FontWeight="Bold" Padding="0"
                                                        Command="{Binding DataContext.RemoveWeaponCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding CanRemove, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        ToolTip="Remove weapon"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add Weapon -->
                            <controls:SearchableReferenceComboBox
                                Margin="0,6,0,0"
                                ItemsSource="{Binding AvailableWeaponsForSearch}"
                                Placeholder="Search and select to add..."
                                SelectionChanged="OnWeaponSelectionChanged"/>
                        </StackPanel>

                        <!-- Armor Column (Right) -->
                        <StackPanel Grid.Column="2">
                            <!-- Armor Header Row -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="ARMOR" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="PROT" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="DEF" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="ENC" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center"/>
                            </Grid>

                            <!-- Armor List -->
                            <ItemsControl ItemsSource="{Binding ArmorList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundDarkBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="4,3" Margin="0,0,0,2"
                                                ToolTip="{Binding ArmorTooltip}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Status indicator -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="3" Height="14" CornerRadius="1" Margin="0,0,2,0"
                                                            Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSessionEdit}" Value="True">
                                                                        <Setter Property="Background" Value="#00CED1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <TextBlock Text="i" FontSize="8" Foreground="#666666"
                                                               Visibility="{Binding IsInherited, Converter={StaticResource BoolToVisibilityConverter}}"
                                                               VerticalAlignment="Center" ToolTip="Inherited"/>
                                                </StackPanel>

                                                <!-- Name (clickable) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name, TargetNullValue='(unknown)'}"
                                                           Foreground="{DynamicResource AccentHighlightBrush}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextDecorations="Underline" Cursor="Hand"
                                                           VerticalAlignment="Center"
                                                           MouseLeftButtonDown="OnEquipmentClick"/>

                                                <!-- PROT -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ProtectionDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- DEF -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding DefenseDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- ENC -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding EncumbranceDisplay}"
                                                           FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Remove button -->
                                                <Button Grid.Column="5" Content="×" Width="18" Height="18"
                                                        FontSize="12" FontWeight="Bold" Padding="0"
                                                        Command="{Binding DataContext.RemoveArmorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding CanRemove, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        ToolTip="Remove armor"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add Armor -->
                            <controls:SearchableReferenceComboBox
                                Margin="0,6,0,0"
                                ItemsSource="{Binding AvailableArmorForSearch}"
                                Placeholder="Search and select to add..."
                                SelectionChanged="OnArmorSelectionChanged"/>
                        </StackPanel>
                    </Grid>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Abilities - Compact Badge Layout -->
            <controls:PropertyGroupControl Header="Abilities" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <!-- Types (read-only, inherited) -->
                        <TextBlock Text="TYPES (inherited)" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding TypeBadges}"
                            AvailableItems="{Binding AvailableTypeBadges}"
                            ShowAddButton="False"
                            NavigateCommand="{Binding NavigateToReferenceCommand}"/>

                        <!-- General (movement, leadership, special, province, stealth, recruitment) -->
                        <TextBlock Text="GENERAL" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding GeneralBadges}"
                            AvailableItems="{Binding AvailableGeneralBadges}"
                            RemoveCommand="{Binding RemoveGeneralBadgeCommand}"
                            AddCommand="{Binding AddGeneralBadgeCommand}"
                            ShowAddButton="True"
                            NavigateCommand="{Binding NavigateToReferenceCommand}"/>

                        <!-- Combat (combat abilities + auras) -->
                        <TextBlock Text="COMBAT" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding CombatBadges}"
                            AvailableItems="{Binding AvailableCombatBadges}"
                            RemoveCommand="{Binding RemoveCombatBadgeCommand}"
                            AddCommand="{Binding AddCombatBadgeCommand}"
                            ShowAddButton="True"
                            NavigateCommand="{Binding NavigateToReferenceCommand}"/>

                        <!-- Resistances (colored value badges) -->
                        <TextBlock Text="RESISTANCES" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding ResistanceBadges}"
                            AvailableItems="{Binding AvailableResistanceBadges}"
                            RemoveCommand="{Binding RemoveResistanceBadgeCommand}"
                            AddCommand="{Binding AddResistanceBadgeCommand}"
                            ShowAddButton="True"
                            NavigateCommand="{Binding NavigateToReferenceCommand}"/>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
