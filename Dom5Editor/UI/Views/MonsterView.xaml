<UserControl x:Class="Dom5Editor.UI.Views.MonsterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sprite Images (compact) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64" Margin="0,0,4,0">
                            <Image Source="{Binding SpriteImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="2" Width="64" Height="64">
                            <Image Source="{Binding Sprite2Image}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <TextBlock Text="{Binding ID, StringFormat='Monster #{0}'}" Style="{DynamicResource MutedText}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="2" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Basic Info Section -->
            <controls:PropertyGroupControl Header="Basic Info" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:StringPropertyEditor Grid.Column="0" Label="Name" Value="{Binding Name, Mode=TwoWay}" Margin="0,0,4,4"/>
                            <controls:StringPropertyEditor Grid.Column="1" Label="Fixed Name" Value="{Binding FixedName, Mode=TwoWay}" IsModified="{Binding IsFixedNameModified}" IsSessionEdit="{Binding IsFixedNameSessionEdit}" Margin="4,0,0,4"/>
                        </Grid>
                        <controls:StringPropertyEditor Label="Description" Value="{Binding Description, Mode=TwoWay}" IsModified="{Binding IsDescriptionModified}" IsSessionEdit="{Binding IsDescriptionSessionEdit}" IsMultiline="True"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:StringPropertyEditor Grid.Column="0" Label="Sprite 1" Value="{Binding Sprite1, Mode=TwoWay}" IsModified="{Binding IsSprite1Modified}" IsSessionEdit="{Binding IsSprite1SessionEdit}" Margin="0,0,4,0"/>
                            <controls:StringPropertyEditor Grid.Column="1" Label="Sprite 2" Value="{Binding Sprite2, Mode=TwoWay}" IsModified="{Binding IsSprite2Modified}" IsSessionEdit="{Binding IsSprite2SessionEdit}" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Copy From Section (shown when monster has copystats/copyspr) -->
            <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
                    Visibility="{Binding HasCopyCommands, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="COPY FROM" FontSize="9" FontWeight="Bold" Foreground="White" Opacity="0.7" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <!-- CopyStats badge -->
                        <Border Background="#2A2A2A" CornerRadius="3" Padding="6,3" Margin="0,0,6,0"
                                Visibility="{Binding HasCopyStats, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="copystats:" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CopyStatsDisplay}" Foreground="#FFD700" FontSize="10" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- CopySpr badge -->
                        <Border Background="#2A2A2A" CornerRadius="3" Padding="6,3" Margin="0,0,6,0"
                                Visibility="{Binding HasCopySpr, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="copyspr:" Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CopySprDisplay}" Foreground="#87CEEB" FontSize="10" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Stats Section (3 columns, compact) -->
            <controls:PropertyGroupControl Header="Stats" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:IntPropertyEditor Grid.Row="0" Grid.Column="0" Label="HP" Value="{Binding Hp, Mode=TwoWay}" IsModified="{Binding IsHpModified}" IsSessionEdit="{Binding IsHpSessionEdit}" IsInherited="{Binding IsHpInherited}" Margin="0,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="0" Grid.Column="1" Label="Size" Value="{Binding Size, Mode=TwoWay}" IsModified="{Binding IsSizeModified}" IsSessionEdit="{Binding IsSizeSessionEdit}" IsInherited="{Binding IsSizeInherited}" Margin="4,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="0" Grid.Column="2" Label="Prot" Value="{Binding Protection, Mode=TwoWay}" IsModified="{Binding IsProtectionModified}" IsSessionEdit="{Binding IsProtectionSessionEdit}" IsInherited="{Binding IsProtectionInherited}" Margin="4,0,0,4"/>

                        <controls:IntPropertyEditor Grid.Row="1" Grid.Column="0" Label="Str" Value="{Binding Strength, Mode=TwoWay}" IsModified="{Binding IsStrengthModified}" IsSessionEdit="{Binding IsStrengthSessionEdit}" IsInherited="{Binding IsStrengthInherited}" Margin="0,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="1" Grid.Column="1" Label="Att" Value="{Binding Attack, Mode=TwoWay}" IsModified="{Binding IsAttackModified}" IsSessionEdit="{Binding IsAttackSessionEdit}" IsInherited="{Binding IsAttackInherited}" Margin="4,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="1" Grid.Column="2" Label="Def" Value="{Binding Defense, Mode=TwoWay}" IsModified="{Binding IsDefenseModified}" IsSessionEdit="{Binding IsDefenseSessionEdit}" IsInherited="{Binding IsDefenseInherited}" Margin="4,0,0,4"/>

                        <controls:IntPropertyEditor Grid.Row="2" Grid.Column="0" Label="Prec" Value="{Binding Precision, Mode=TwoWay}" IsModified="{Binding IsPrecisionModified}" IsSessionEdit="{Binding IsPrecisionSessionEdit}" IsInherited="{Binding IsPrecisionInherited}" Margin="0,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="2" Grid.Column="1" Label="Enc" Value="{Binding Encumbrance, Mode=TwoWay}" IsModified="{Binding IsEncumbranceModified}" IsSessionEdit="{Binding IsEncumbranceSessionEdit}" IsInherited="{Binding IsEncumbranceInherited}" Margin="4,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="2" Grid.Column="2" Label="MR" Value="{Binding MagicResistance, Mode=TwoWay}" IsModified="{Binding IsMagicResistanceModified}" IsSessionEdit="{Binding IsMagicResistanceSessionEdit}" IsInherited="{Binding IsMagicResistanceInherited}" Margin="4,0,0,4"/>

                        <controls:IntPropertyEditor Grid.Row="3" Grid.Column="0" Label="Mor" Value="{Binding Morale, Mode=TwoWay}" IsModified="{Binding IsMoraleModified}" IsSessionEdit="{Binding IsMoraleSessionEdit}" IsInherited="{Binding IsMoraleInherited}" Margin="0,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="3" Grid.Column="1" Label="AP" Value="{Binding ActionPoints, Mode=TwoWay}" IsModified="{Binding IsActionPointsModified}" IsSessionEdit="{Binding IsActionPointsSessionEdit}" IsInherited="{Binding IsActionPointsInherited}" Margin="4,0,4,4"/>
                        <controls:IntPropertyEditor Grid.Row="3" Grid.Column="2" Label="Move" Value="{Binding MapMove, Mode=TwoWay}" IsModified="{Binding IsMapMoveModified}" IsSessionEdit="{Binding IsMapMoveSessionEdit}" IsInherited="{Binding IsMapMoveInherited}" Margin="4,0,0,4"/>

                        <controls:IntPropertyEditor Grid.Row="4" Grid.Column="0" Label="Eyes" Value="{Binding Eyes, Mode=TwoWay}" IsModified="{Binding IsEyesModified}" IsSessionEdit="{Binding IsEyesSessionEdit}" IsInherited="{Binding IsEyesInherited}" Margin="0,0,4,0"/>
                    </Grid>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Magic Paths Section -->
            <controls:PropertyGroupControl Header="Magic Paths" IsExpanded="False">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:MagicPathEditor MagicPaths="{Binding MagicPathsList}"
                                              AvailablePaths="{Binding AvailableMagicPaths}"
                                              PathAdded="OnMagicPathAdded"
                                              PathRemoved="OnMagicPathRemoved"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Abilities - Compact Badge Layout -->
            <controls:PropertyGroupControl Header="Abilities" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <!-- Types (read-only, inherited) -->
                        <TextBlock Text="TYPES (inherited)" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding TypeBadges}"
                            AvailableItems="{Binding AvailableTypeBadges}"
                            ShowAddButton="False"/>

                        <!-- General (movement, leadership, special, province, stealth, recruitment) -->
                        <TextBlock Text="GENERAL" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding GeneralBadges}"
                            AvailableItems="{Binding AvailableGeneralBadges}"
                            RemoveCommand="{Binding RemoveGeneralBadgeCommand}"
                            AddCommand="{Binding AddGeneralBadgeCommand}"
                            ShowAddButton="True"/>

                        <!-- Combat (combat abilities + auras) -->
                        <TextBlock Text="COMBAT" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding CombatBadges}"
                            AvailableItems="{Binding AvailableCombatBadges}"
                            RemoveCommand="{Binding RemoveCombatBadgeCommand}"
                            AddCommand="{Binding AddCombatBadgeCommand}"
                            ShowAddButton="True"/>

                        <!-- Resistances (colored value badges) -->
                        <TextBlock Text="RESISTANCES" FontSize="8" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2"/>
                        <controls:BadgeWrapPanel
                            ItemsSource="{Binding ResistanceBadges}"
                            AvailableItems="{Binding AvailableResistanceBadges}"
                            RemoveCommand="{Binding RemoveResistanceBadgeCommand}"
                            AddCommand="{Binding AddResistanceBadgeCommand}"
                            ShowAddButton="True"/>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
