<UserControl x:Class="Dom5Editor.UI.Views.WeaponView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <TextBlock Text="{Binding ID, StringFormat='Weapon #{0}'}" Style="{DynamicResource MutedText}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Copy From Section (editable) -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Copy Weapon selector -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Copy From:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <controls:SearchableReferenceComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding AvailableWeaponsForCopy}"
                            SelectedId="{Binding CopyWeaponId, Mode=TwoWay}"
                            Placeholder="Select weapon to copy from..."
                            ToolTip="Select a weapon to copy properties from"/>
                        <Button Grid.Column="2" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Clear copy weapon"
                                Visibility="{Binding HasCopyWeapon, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnClearCopyWeaponClick"/>
                        <Button Grid.Column="3" Content="→" Width="24" Height="24" Margin="4,0,0,0"
                                ToolTip="Navigate to source weapon"
                                Visibility="{Binding HasCopyWeapon, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OnCopyWeaponClick"/>
                    </Grid>
                    <!-- Clear Command -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Clear:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <CheckBox Grid.Column="1" Content="Clear All" IsChecked="{Binding HasClear, Mode=TwoWay}"
                                  ToolTip="Clear all inherited properties"
                                  Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Basic Info Section -->
            <controls:PropertyGroupControl Header="Basic Info" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <controls:StringPropertyEditor Label="Name" Value="{Binding Name, Mode=TwoWay}" Margin="0,0,0,4"/>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Stats Section - JSON-driven badge panel -->
            <controls:PropertyGroupControl Header="Stats" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <StackPanel>
                        <!-- Damage with dynamic editor: int for normal, ref for summon, readonly for cloud -->
                        <controls:DynamicPropertyEditor
                            Margin="0,0,0,8"
                            Label="{Binding DamageLabel}"
                            EditorMode="{Binding DamageEditorMode}"
                            IntValue="{Binding Damage, Mode=TwoWay}"
                            RefSelectedId="{Binding DamageMonsterId, Mode=TwoWay}"
                            RefItemsSource="{Binding AvailableMonstersForDamage}"
                            ReadOnlyText="{Binding DamageReadOnlyText}"
                            SecondaryDisplayText="{Binding DamageSecondaryText}"
                            SecondaryDisplayColor="#00BFFF"
                            IsModified="{Binding IsDamageModified}"
                            IsSessionEdit="{Binding IsDamageSessionEdit}"
                            IsInherited="{Binding IsDamageInherited}"/>

                        <controls:BadgeGridPanel
                            ItemsSource="{Binding StatsBadges}"
                            AvailableItems="{Binding AvailableStatsBadges}"
                            RemoveCommand="{Binding RemoveStatsBadgeCommand}"
                            AddCommand="{Binding AddStatsBadgeCommand}"
                            Columns="4"/>

                        <!-- Damage Types (derived summary) -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding DamageTypes, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Damage Type: " FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DamageTypes}" FontSize="11" Foreground="#9370DB" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Special Properties (derived summary) -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding SpecialProperties, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Properties: " FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SpecialProperties}" FontSize="11" Foreground="#FFD700" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Secondary Effect (derived summary) -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding HasSecondaryEffect, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Secondary Effect: " FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SecondaryEffectDisplay}" FontSize="11" Foreground="#00BFFF" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Properties - Single Unified Badge Panel -->
            <controls:PropertyGroupControl Header="Properties" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeWrapPanel
                        ItemsSource="{Binding PropertyBadges}"
                        AvailableItems="{Binding AvailablePropertyBadges}"
                        RemoveCommand="{Binding RemovePropertyBadgeCommand}"
                        AddCommand="{Binding AddPropertyBadgeCommand}"
                        NavigateCommand="{Binding NavigateToReferenceCommand}"
                        ShowAddButton="True"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
