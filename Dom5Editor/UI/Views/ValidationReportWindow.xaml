<Window x:Class="Dom5Editor.UI.Views.ValidationReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Validation Report"
        Height="500" Width="700"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource AppWindowStyle}"
        KeyDown="Window_KeyDown">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Summary Counts -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundLightBrush}"
                CornerRadius="6"
                Padding="16,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <!-- Error count -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <Ellipse Width="12" Height="12" Fill="#FF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ErrorCountText"
                               Text="0 Errors"
                               Style="{DynamicResource TextBlockBase}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Warning count -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <Polygon Points="6,0 12,10 0,10" Fill="#FFAA00" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="WarningCountText"
                               Text="0 Warnings"
                               Style="{DynamicResource TextBlockBase}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Info count -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="#4488FF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="InfoCountText"
                               Text="0 Info"
                               Style="{DynamicResource TextBlockBase}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter Row -->
        <Border Grid.Row="1"
                Padding="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Severity Filters -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <CheckBox x:Name="ShowErrorsCheck"
                              Content="Errors"
                              Style="{DynamicResource CheckBoxBase}"
                              IsChecked="True"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed"
                              Margin="0,0,16,0"/>
                    <CheckBox x:Name="ShowWarningsCheck"
                              Content="Warnings"
                              Style="{DynamicResource CheckBoxBase}"
                              IsChecked="True"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed"
                              Margin="0,0,16,0"/>
                    <CheckBox x:Name="ShowInfoCheck"
                              Content="Info"
                              Style="{DynamicResource CheckBoxBase}"
                              IsChecked="False"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed"/>
                </StackPanel>

                <!-- Search Box -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Style="{DynamicResource TextBoxBase}"
                         Margin="24,0,0,0"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- Issues List -->
        <ListBox x:Name="IssuesListBox"
                 Grid.Row="2"
                 Style="{DynamicResource ListBoxBase}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="IssuesListBox_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemBase}">
                    <Setter Property="Padding" Value="12,10"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Severity Icon -->
                        <Grid Grid.Column="0" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Top">
                            <!-- Error icon -->
                            <Ellipse x:Name="ErrorIcon" Fill="#FF4444" Visibility="Collapsed"/>
                            <!-- Warning icon -->
                            <Polygon x:Name="WarningIcon" Points="8,0 16,14 0,14" Fill="#FFAA00" Visibility="Collapsed"/>
                            <!-- Info icon -->
                            <Ellipse x:Name="InfoIcon" Fill="#4488FF" Visibility="Collapsed"/>
                        </Grid>

                        <!-- Message and Entity Info -->
                        <StackPanel Grid.Column="1">
                            <!-- Category and Message -->
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding Category, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Category}"
                                               Style="{DynamicResource MutedText}"
                                               FontSize="10"/>
                                </Border>
                            </StackPanel>

                            <!-- Message -->
                            <TextBlock Text="{Binding Message}"
                                       Style="{DynamicResource TextBlockBase}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>

                            <!-- Entity Info -->
                            <TextBlock x:Name="EntityInfo"
                                       Style="{DynamicResource MutedText}"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding EntityDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                                <Run Text="{Binding EntityDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Navigate Button -->
                        <Button x:Name="NavigateButton"
                                Grid.Column="2"
                                Content="Go To"
                                Style="{DynamicResource ButtonSmall}"
                                VerticalAlignment="Center"
                                Visibility="{Binding CanNavigate, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="NavigateButton_Click"
                                Tag="{Binding}"/>
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                            <Setter TargetName="ErrorIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                            <Setter TargetName="WarningIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="Info">
                            <Setter TargetName="InfoIcon" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <Border Grid.Row="3"
                Padding="0,12,0,0">
            <DockPanel>
                <TextBlock x:Name="FilteredCountText"
                           Text="0 issues"
                           Style="{DynamicResource MutedText}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <Button Content="Close"
                        Style="{DynamicResource ButtonBase}"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        IsCancel="True"/>
                <Button Content="Export"
                        Style="{DynamicResource ButtonBase}"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Margin="0,0,8,0"
                        Click="ExportButton_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
