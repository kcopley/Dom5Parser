<UserControl x:Class="Dom5Editor.UI.Views.BlessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Dom5Editor.UI.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Header with ID and source indicator -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" Style="{DynamicResource HeaderText}" FontSize="18" Foreground="{DynamicResource AccentHighlightBrush}"/>
                        <TextBlock Text="{Binding ID, StringFormat='Bless #{0}'}" Style="{DynamicResource MutedText}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Description -->
            <Border Background="{DynamicResource BackgroundDarkBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock Text="Bless effects define bonuses granted to sacred units when blessed. Each bless requires specific magic paths and may have scale requirements."
                           Style="{DynamicResource MutedText}" FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <!-- Clear Commands -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Clear:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <CheckBox Content="Clear Scales" IsChecked="{Binding HasClearScales, Mode=TwoWay}"
                                  ToolTip="Clear all scale requirements for this bless"
                                  Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,16,0"/>
                        <CheckBox Content="Clear Effects" IsChecked="{Binding HasClearFx, Mode=TwoWay}"
                                  ToolTip="Clear all bless effects"
                                  Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Path Requirements Section -->
            <controls:PropertyGroupControl Header="Path Requirements" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeWrapPanel
                        ItemsSource="{Binding PathBadges}"
                        AvailableItems="{Binding AvailablePathBadges}"
                        RemoveCommand="{Binding RemovePathBadgeCommand}"
                        AddCommand="{Binding AddPathBadgeCommand}"
                        NavigateCommand="{Binding NavigateToReferenceCommand}"
                        ShowAddButton="True"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

            <!-- Scale Requirements Section -->
            <controls:PropertyGroupControl Header="Scale Requirements" IsExpanded="True">
                <controls:PropertyGroupControl.GroupContent>
                    <controls:BadgeWrapPanel
                        ItemsSource="{Binding ScalesBadges}"
                        AvailableItems="{Binding AvailableScalesBadges}"
                        RemoveCommand="{Binding RemoveScalesBadgeCommand}"
                        AddCommand="{Binding AddScalesBadgeCommand}"
                        NavigateCommand="{Binding NavigateToReferenceCommand}"
                        ShowAddButton="True"/>
                </controls:PropertyGroupControl.GroupContent>
            </controls:PropertyGroupControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
