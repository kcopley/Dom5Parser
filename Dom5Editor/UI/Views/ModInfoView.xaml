<UserControl x:Class="Dom5Editor.UI.Views.ModInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             Background="{DynamicResource BackgroundMediumBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Mod Information" Style="{DynamicResource HeaderText}" FontSize="20" Foreground="{DynamicResource AccentHighlightBrush}"/>
                    <TextBlock Text="Configure your mod's metadata and display settings" Style="{DynamicResource MutedText}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Mod Name -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Mod Name:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding ModName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxBase}" FontSize="12"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" Text="A short name displayed in the mod preferences screen."
                               Style="{DynamicResource MutedText}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Description -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Description:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Top" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding ModDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxBase}" FontSize="12"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" Text="A description of what the mod does, who created it, etc."
                               Style="{DynamicResource MutedText}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Version -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Version:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding ModVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxBase}" FontSize="12" Width="100" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" Text="The version number of your mod (e.g., 1.00 or 1.10)."
                               Style="{DynamicResource MutedText}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Dom Version -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Dom Version:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding ModDomVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxBase}" FontSize="12" Width="100" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" Text="Minimum required version of Dominions (e.g., 6.00). Leave empty if unsure."
                               Style="{DynamicResource MutedText}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Icon -->
            <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Icon:" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding ModIcon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource TextBoxBase}" FontSize="12"/>

                    <TextBlock Grid.Column="1" Grid.Row="1" Text="A banner image for your mod (128x32 or 256x64 TGA file)."
                               Style="{DynamicResource MutedText}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
