  "layout": {
    "monster": ["stats", "magicpaths", "types", "general", "combat", "resistances"]
  },
  "renderers": {
    "badge": {
      "description": "Standard compact badge with optional value",
      "supportedTypes": ["flag", "int"]
    },
    "coloredBadge": {
      "description": "Colored badge for resistances and special values",
      "supportedTypes": ["int"],
      "requiresColor": true
    },
    "statsGrid": {
      "description": "3-column grid layout for core stats",
      "supportedTypes": ["int"],
      "columns": 3
    },
    "magicPathEditor": {
      "description": "Custom magic path editor with colored level badges",
      "supportedTypes": ["path", "randompaths"],
      "pathColors": {
        "F": "#FF4500",
        "A": "#87CEEB",
        "W": "#4169E1",
        "E": "#8B4513",
        "S": "#FFD700",
        "D": "#2F4F4F",
        "N": "#228B22",
        "B": "#8B0000",
        "H": "#FFFFFF"
      }
    }
